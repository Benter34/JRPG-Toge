  m_Script: {fileID: 11500000, guid: 7c4b594b72eb0e74388bc1421a973f0d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  dialogueBubble: {fileID: 537398150}
  openingLines:
  - Who's there!
  - Ohh hi what are you doing here
  - Its danger here
  - And who are you i never seen you in the village
  firstQuestion: And who are you i never seen you in the village
  firstOption1: I don't know
  firstOption2: its secret
  firstOption1ResponseLines:
  - Oww that unfortune, anyway im Frank people called me OldMan nice meeting you
  - I was clearing the village from monster around forrest near the village
  - Can you fight? i hope you can fight.
  - Here sword clear any monster in this forrest and find a village after
  - Be carefull with the monster
  firstOption2ResponseLines:
  - Huhhhhh, alright stranger since your normal but you suspicious
  - You have to help me clear the monster near the village in this forrest
  - Here the sword, slash them stranger
  - after you clear the monster find the village nearby
  - becarefull stranger we will meet again
  secondQuestion: Help OldMan
  secondOption1: I will help you
  secondOption2: Im not helping
  secondOption1ResponseLines:
  - Okey lead the way
  secondOption2ResponseLines:
  - Well to bad you are
  - Go find any monster
  npcFollower: {fileID: 858557526}
  startFollowAfterDialogue: 1
